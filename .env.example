# Copy this to .env and fill in values. .env is git-ignored.

# --- LLM ---
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=meridian-support-chatbot
OPENROUTER_APP_URL=https://github.com/LarryKarani/mcp-dry-run

# --- MCP server ---
MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
MCP_TRANSPORT=http             # http (Streamable HTTP) | sse
MCP_CALL_TIMEOUT_SECONDS=10.0

# --- LangSmith observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=meridian-support

# --- Guardrails ---
MAX_USER_MESSAGE_CHARS=2000

# --- App ---
LOG_LEVEL=INFO
APP_PORT=8000
