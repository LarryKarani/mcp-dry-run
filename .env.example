# Copy this to .env and fill in values. .env is git-ignored.

# --- LLM ---
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=mcp-bootcamp-dryrun
OPENROUTER_APP_URL=https://github.com/yourname/mcp-bootcamp

# --- MCP server ---
MCP_SERVER_URL=http://127.0.0.1:8765/mcp
MCP_TRANSPORT=http             # http (Streamable HTTP) | sse
MCP_CALL_TIMEOUT_SECONDS=10.0

# --- LangSmith observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mcp-bootcamp-dryrun

# --- Guardrails ---
MAX_USER_MESSAGE_CHARS=2000

# --- App ---
LOG_LEVEL=INFO
APP_PORT=8000
